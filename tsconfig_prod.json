{
  "compilerOptions": {
    "module": "commonjs",
    "types": ["node", "express"],
    "esModuleInterop": true,
    "target": "es6",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "lib": ["es2015", "esnext", "dom"], 
  "include": ["src/**/*", "index.ts", "server.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
