{
  "scripts": {
    "start": "tsc && node ./dist/server.js",
    "prod": "cp .env.prod .env && tsc -p tsconfig_prod.json && pm2 restart ecosystem.config.js --env production",
    "lint": "eslint . --ext .ts",
    "dev": "cp .env.dev .env && nodemon server.ts",
    "test": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/.*.test.ts",
    "testComments": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/comments.test.ts",
    "testPosts": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/posts.test.ts",
    "testAuth": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/auth.test.ts",
    "testUsers": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/users.test.ts",
    "testImageUpload": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/imageUpload.test.ts",
    "testMongoFilterSanitizer": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/unit_tests/mongoFilterSanitizer.test.ts",
    "testOllamaService": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/unit_tests/ollamaService.test.ts",
    "testPostSearch": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/mockSearch.test.ts",
    "testAISearch": "tsc && jest --runInBand --detectOpenHandles --forceExit --testPathPatterns=tests/aiSearch.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2"
  }
}
